rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidProduct(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.price is number &&
             data.category is string &&
             data.image is string && data.image.size() <= 1000;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProduct(request.resource.data);
      allow update: if isSignedIn() && isValidProduct(request.resource.data);
      allow delete: if isSignedIn();
    }
    
    // Testing collection
    match /test/connection {
      allow read: if true;
    }
  }
}

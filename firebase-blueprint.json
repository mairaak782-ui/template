{
  "entities": {
    "submission": {
      "title": "Submission",
      "description": "User form submissions from contact and lead forms",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User name" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "whatsapp": { "type": "string", "description": "User WhatsApp number" },
        "message": { "type": "string", "description": "The message they sent" },
        "type": { "type": "string", "enum": ["contact", "lead", "order", "newsletter"], "description": "Type of submission" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of creation" }
      },
      "required": ["email", "createdAt"]
    },
    "product": {
      "title": "Product",
      "description": "Digital assets or affiliate products",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["digital", "affiliate"] },
        "image": { "type": "string" },
        "affiliateLink": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "price", "createdAt"]
    },
    "feedback": {
      "title": "Feedback",
      "description": "User feedback and suggestions",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "category": { "type": "string" },
        "message": { "type": "string" },
        "language": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "message", "createdAt"]
    }
  },
  "firestore": {
    "/submissions/{submissionId}": {
      "schema": "submission",
      "description": "Collection for storing user submissions"
    },
    "/products/{productId}": {
      "schema": "product",
      "description": "Inventory of products and assets"
    },
    "/feedbacks/{feedbackId}": {
      "schema": "feedback",
      "description": "User feedback collection"
    }
  }
}

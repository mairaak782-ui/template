{
  "entities": {
    "Product": {
      "title": "Product Entity",
      "description": "Represents a store item with e-commerce metadata and AI descriptions.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the product" },
        "description": { "type": "string", "description": "SEO optimized description" },
        "price": { "type": "number", "description": "Price in USD" },
        "category": { "type": "string", "description": "Product category" },
        "type": { "type": "string", "enum": ["digital", "affiliate"], "description": "Whether this is an owned digital asset or an affiliate recommendation" },
        "image": { "type": "string", "description": "Main product image URL" },
        "badge": { "type": "string", "description": "Promotional badge (e.g., 'New', 'Popular')" },
        "affiliateLink": { "type": "string", "description": "Affiliate referral link" },
        "features": { "type": "array", "items": { "type": "string" }, "description": "Key feature highlights" },
        "mockupPrompt": { "type": "string", "description": "DALL-E/Midjourney prompt for 3D mockup" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "price", "category", "image"]
    },
    "Feedback": {
      "title": "Feedback & Suggestion",
      "description": "Represents a user request or problem report for new digital assets.",
      "type": "object",
      "properties": {
        "userName": { "type": "string", "description": "Name of the user" },
        "userEmail": { "type": "string", "description": "Contact email" },
        "category": { "type": "string", "enum": ["Suggestion", "Problem", "Feature Request"], "description": "Type of feedback" },
        "message": { "type": "string", "description": "The content of the feedback or request" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "category", "message", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of available digital assets and templates."
    },
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of user suggestions and feedback."
    }
  }
}
